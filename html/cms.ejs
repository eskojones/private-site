<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>
<body>
    <%- include('partials/header') %>

    <main>
        <section class="hero">
            <h1>CMS Dashboard</h1>
            <p>Manage your site content and pages.</p>
        </section>

        <section class="cms-container">
            <div id="cms-actions" class="cms-actions">
                <button id="btn-new-page" class="cta-button">Create New Page</button>
            </div>

            <div id="pages-list">
                <h3>Page Explorer</h3>
                <div id="cms-tree-container" class="tree-view">
                    <!-- Tree will be injected here -->
                </div>
            </div>

            <div id="page-editor" class="hidden">
                <h2 id="editor-title">Create Page</h2>
                <form id="cms-form">
                    <input type="hidden" id="edit-old-slug">
                    <div class="form-group">
                        <label>Slug (URL):</label>
                        <input type="text" id="page-slug" required placeholder="e.g., about/team">
                    </div>
                    <div class="form-group">
                        <label>Nav Title:</label>
                        <input type="text" id="page-title" required placeholder="e.g., Our Team">
                    </div>
                    <div class="form-group">
                        <label>Hero Title:</label>
                        <input type="text" id="hero-title" required placeholder="Main Page Heading">
                    </div>
                    <div class="form-group">
                        <label>Hero Subtitle:</label>
                        <input type="text" id="hero-subtitle" required placeholder="Sub Heading under Hero">
                    </div>
                    <div class="form-group">
                        <label>Content Chunks (JSON Array):</label>
                        <textarea id="page-content" placeholder="Enter content as a JSON array of sections"></textarea>
                    </div>
                    <div class="form-group">
                        <button type="submit" class="cta-button">Save Page</button>
                        <button type="button" id="btn-cancel-edit" style="background: #ccc; color: #333;" class="cta-button">Cancel</button>
                    </div>
                </form>
            </div>
        </section>
    </main>
                </form>
            </div>
        </section>
    </main>

    <%- include('partials/scripts') %>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const user = localStorage.getItem('user');
            const isAdmin = localStorage.getItem('isAdmin') === 'true';
            
            if (!user || !isAdmin) {
                window.location.href = '/';
                return;
            }

            const treeContainer = document.getElementById('cms-tree-container');
            const editor = document.getElementById('page-editor');
            const cmsForm = document.getElementById('cms-form');
            const btnNewPage = document.getElementById('btn-new-page');
            const btnCancel = document.getElementById('btn-cancel-edit');

            const adminHeaders = {
                'Content-Type': 'application/json',
                'x-admin-status': 'true'
            };

            function buildTree(pages) {
                const root = {};
                pages.forEach(page => {
                    const parts = page.slug === 'index' ? ['Home'] : page.slug.split('/');
                    let current = root;
                    parts.forEach((part, index) => {
                        if (!current[part]) {
                            current[part] = { 
                                children: {}, 
                                page: index === parts.length - 1 ? page : null,
                                label: part
                            };
                        }
                        current = current[part].children;
                    });
                });
                return root;
            }

            function renderTree(nodes, container) {
                Object.values(nodes).forEach(node => {
                    const nodeEl = document.createElement('div');
                    nodeEl.className = 'tree-node';
                    
                    const contentEl = document.createElement('div');
                    contentEl.className = 'node-content';
                    
                    const labelEl = document.createElement('div');
                    labelEl.className = 'node-label';
                    labelEl.innerHTML = `
                        <span class="icon">${node.page ? '📄' : '📁'}</span>
                        <span>${node.page ? node.page.title : node.label}</span>
                        <span class="slug">${node.page ? '(' + node.page.slug + ')' : ''}</span>
                    `;
                    
                    contentEl.appendChild(labelEl);

                    if (node.page) {
                        const actionsEl = document.createElement('div');
                        actionsEl.className = 'node-actions';
                        actionsEl.innerHTML = `
                            <button onclick="editPage('${node.page.slug}')">Edit</button>
                            <button onclick="deletePage('${node.page.slug}')" style="color: red;">Delete</button>
                        `;
                        contentEl.appendChild(actionsEl);
                    }
                    
                    nodeEl.appendChild(contentEl);

                    if (Object.keys(node.children).length > 0) {
                        const childrenEl = document.createElement('div');
                        childrenEl.className = 'node-children';
                        renderTree(node.children, childrenEl);
                        nodeEl.appendChild(childrenEl);
                    }

                    container.appendChild(nodeEl);
                });
            }

            async function loadPages() {
                const res = await fetch('/api/nav');
                const pages = await res.json();
                treeContainer.innerHTML = '';
                const tree = buildTree(pages);
                renderTree(tree, treeContainer);
            }

            window.editPage = async (slug) => {
                const res = await fetch(`/api/pages/${slug}`, {
                    headers: adminHeaders
                });
                if (!res.ok) {
                    alert('Failed to fetch page data. Admins only.');
                    return;
                }
                const data = await res.json();
                
                document.getElementById('edit-old-slug').value = data.slug;
                document.getElementById('page-slug').value = data.slug;
                document.getElementById('page-title').value = data.title;
                document.getElementById('hero-title').value = data.hero.title;
                document.getElementById('hero-subtitle').value = data.hero.subtitle;
                document.getElementById('page-content').value = JSON.stringify(data.content, null, 2);
                
                document.getElementById('editor-title').textContent = 'Edit Page';
                editor.classList.remove('hidden');
            };

            window.deletePage = async (slug) => {
                if (slug === 'index') {
                    alert('Cannot delete the home page!');
                    return;
                }
                if (confirm(`Are you sure you want to delete /${slug}?`)) {
                    await fetch(`/api/pages/${slug}`, { 
                        method: 'DELETE',
                        headers: adminHeaders
                    });
                    loadPages();
                    if (typeof initNavigation === 'function') initNavigation();
                }
            };

            btnNewPage.addEventListener('click', () => {
                cmsForm.reset();
                document.getElementById('edit-old-slug').value = '';
                document.getElementById('page-content').value = '[]';
                document.getElementById('editor-title').textContent = 'Create Page';
                editor.classList.remove('hidden');
            });

            btnCancel.addEventListener('click', () => {
                editor.classList.add('hidden');
            });

            cmsForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const oldSlug = document.getElementById('edit-old-slug').value;
                const pageData = {
                    slug: document.getElementById('page-slug').value,
                    title: document.getElementById('page-title').value,
                    hero: {
                        title: document.getElementById('hero-title').value,
                        subtitle: document.getElementById('hero-subtitle').value
                    },
                    content: JSON.parse(document.getElementById('page-content').value || '[]')
                };

                const method = oldSlug ? 'PUT' : 'POST';
                const url = oldSlug ? `/api/pages/${oldSlug}` : '/api/pages';

                const res = await fetch(url, {
                    method: method,
                    headers: adminHeaders,
                    body: JSON.stringify(pageData)
                });

                if (res.ok) {
                    editor.classList.add('hidden');
                    loadPages();
                    if (typeof initNavigation === 'function') initNavigation();
                } else {
                    const err = await res.json();
                    alert('Error: ' + err.error);
                }
            });

            loadPages();
        });
    </script>
</body>
</html>
